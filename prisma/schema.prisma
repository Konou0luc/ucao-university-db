generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum AdminRole {
  SUPER_ADMIN
  STANDARD_ADMIN
}

enum EnrollmentStatus {
  ACTIVE
  SUSPENDED
  COMPLETED
  WITHDRAWN
}

model Faculty {
  id          String       @id @default(cuid())
  name        String       @unique @db.VarChar(120)
  code        String       @unique @db.VarChar(20)
  isActive    Boolean      @default(true)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  departments Department[]

  @@index([isActive])
  @@map("faculties")
}

model Department {
  id        String    @id @default(cuid())
  facultyId String
  name      String    @db.VarChar(120)
  code      String    @db.VarChar(20)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  faculty   Faculty   @relation(fields: [facultyId], references: [id], onDelete: Restrict)
  students  Student[]

  @@unique([facultyId, code])
  @@index([facultyId, isActive])
  @@map("departments")
}

model Level {
  id        String    @id @default(cuid())
  name      String    @unique @db.VarChar(50)
  rank      Int       @unique
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  students  Student[]

  @@index([isActive])
  @@map("levels")
}

model Student {
  id           String       @id @default(cuid())
  matricule    String       @unique @db.VarChar(32)
  firstName    String       @db.VarChar(120)
  lastName     String       @db.VarChar(120)
  email        String       @unique @db.VarChar(255)
  phone        String?      @db.VarChar(30)
  departmentId String
  levelId      String
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  department   Department   @relation(fields: [departmentId], references: [id], onDelete: Restrict)
  level        Level        @relation(fields: [levelId], references: [id], onDelete: Restrict)
  enrollments  Enrollment[]

  @@index([matricule])
  @@index([email])
  @@index([departmentId, levelId])
  @@index([isActive])
  @@map("students")
}

model Enrollment {
  id           String           @id @default(cuid())
  studentId    String
  academicYear String           @db.VarChar(20)
  status       EnrollmentStatus @default(ACTIVE)
  isCurrent    Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  student      Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@unique([studentId, academicYear])
  @@index([academicYear, status])
  @@index([studentId, isCurrent])
  @@map("enrollments")
}

model Admin {
  id           String    @id @default(cuid())
  email        String    @unique @db.VarChar(255)
  passwordHash String    @db.VarChar(255)
  role         AdminRole @default(STANDARD_ADMIN)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([role, isActive])
  @@map("admins")
}

model RefreshToken {
  id        String    @id @default(cuid())
  adminId   String
  tokenHash String    @unique @db.VarChar(255)
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())

  @@index([adminId, expiresAt])
  @@index([revokedAt])
  @@map("refresh_tokens")
}

model AuditLog {
  id        String   @id @default(cuid())
  adminId   String?
  action    String   @db.VarChar(120)
  entity    String   @db.VarChar(80)
  entityId  String?  @db.VarChar(80)
  severity  String   @db.VarChar(20)
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([action, createdAt])
  @@index([entity, entityId])
  @@map("audit_logs")
}
